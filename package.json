{
  "name": "sa360",
  "private": true,
  "version": "0.1.1",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev:api": "pnpm --filter @sa360/api dev",
    "dev:worker": "pnpm --filter @sa360/worker dev",
    "dev:admin-coc": "pnpm --filter @sa360/admin-coc dev",
    "build": "turbo run build",
    "build:api": "pnpm prisma:generate && pnpm --filter @sa360/shared build && pnpm --filter @sa360/api build",
    "build:worker": "pnpm prisma:generate && pnpm --filter @sa360/shared build && pnpm --filter @sa360/worker build",
    "build:admin-coc": "pnpm --filter @sa360/admin-coc build",
    "dev": "turbo run dev --parallel",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "tsx prisma/seed.ts",
    "seed:guidance": "tsx prisma/seed-guidance.ts",
    "smoke:workspace:ps": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/smoke-agent-workspace.ps1",
    "smoke:workspace:bash": "bash scripts/smoke-agent-workspace.sh"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "@types/node": "^25.4.0",
    "dotenv": "^16.6.1",
    "prisma": "^6.19.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "turbo": "^2.8.16",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@prisma/client": "6.19.2"
  },
  "engines": {
    "node": "22.x"
  },
  "pnpm": {
    "overrides": {
      "ioredis": "5.9.3"
    }
  }
}