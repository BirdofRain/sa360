  @@index([masterClientAccountId, createdAt])
  @@index([sourceLeadUid])
  @@index([sourceEventUuid])
  @@index([matched, createdAt])
  @@index([validationStatus, createdAt])
  @@index([cleanupStatus, createdAt])
}

/// Shadow delivery plan for a routing decision (no GHL/Sheets/Zapier execution).
model LeadDeliveryPlan {
