generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ClientConfig {
  id              String   @id @default(cuid())
  clientAccountId String   @unique
  clientName      String?
  metaPixelId     String?
  metaDatasetId   String?
  metaAccessToken String?
  metaSyncEnabled Boolean  @default(true)
  defaultCurrency String   @default("USD")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model LeadAttribution {
  id             String    @id @default(cuid())
  leadUid        String    @unique
  contactIdGhl   String?
  sourcePlatform String?
  sourceType     String?
  campaignId     String?
  campaignName   String?
  adsetId        String?
  adsetName      String?
  adId           String?
  adName         String?
  fbclid         String?
  utmSource      String?
  utmMedium      String?
  utmCampaign    String?
  utmContent     String?
  utmTerm        String?
  firstTouchAt   DateTime?
  latestTouchAt  DateTime?
}

enum LeadProofStatus {
  UNREVIEWED
  PROOF_ATTACHED
  PROOF_MISSING
  NEEDS_REVIEW
  REJECTED
}

enum LeadVerificationStatus {
  UNCHECKED
  PASSED
  FAILED
  NEEDS_REVIEW
}

enum LeadDuplicateStatus {
  UNCHECKED
  UNIQUE
  DUPLICATE_GLOBAL
  DUPLICATE_BUYER
  DUPLICATE_RECENT
  POSSIBLE_MATCH
}

enum LeadVerificationApprovalActionType {
  APPROVE_UNIQUE
  REVOKE_TO_REVIEW
}

enum LeadVerificationApprovalStatus {
  applied
  rejected
  idempotent_replay
}

enum Lf2CheckpointAActionType {
  CREATE_CONFIG
  REVOKE_CONFIG
}

enum Lf2CheckpointAStatus {
  applied
  rejected
  idempotent_replay
}

enum LeadProofReviewActionType {
  APPROVE_PROOF
  REJECT_PROOF
  REVOKE_TO_REVIEW
}

enum LeadProofReviewStatus {
  applied
  rejected
  idempotent_replay
}

enum LeadProofArtifactProvider {
  leadcapture_io
  leadconduit_facebook
  meta_lead_ads
  trustedform
  manual
  unknown
}

enum LeadProofArtifactType {
  CONSENT_CERTIFICATE
  CRYPTOGRAPHIC_INTEGRITY
}

enum LeadProofArtifactStatus {
  CAPTURED
  MISSING
  NEEDS_REVIEW
}

model LeadProof {
  id                   String              @id @default(cuid())
  leadUid              String              @unique
  sourceLeadId         String?
  sourceLane           String?
  sourcePlatform       String?
  sourceType           String?
  campaignId           String?
  campaignName         String?
  adsetId              String?
  adsetName            String?
  adId                 String?
  adName               String?
  formId               String?
  formName             String?
  landingPageUrl       String?
  referrerUrl          String?
  consentText          String?             @db.Text
  consentVersion       String?
  consentCapturedAt    DateTime?
  privacyPolicyVersion String?
  termsVersion         String?
  submittedAt          DateTime?
  ipAddress            String?
  userAgent            String?             @db.Text
  phoneRaw             String?
  phoneE164            String?
  email                String?
  proofStatus          LeadProofStatus     @default(UNREVIEWED)
  proofMissingReasons  Json?
  rawSourcePayload     Json?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  proofArtifacts       LeadProofArtifact[]

  @@index([proofStatus, updatedAt])
  @@index([sourceLane, updatedAt])
  @@index([campaignId, updatedAt])
}

model LeadProofArtifact {
  id                  String                    @id @default(cuid())
  leadProofId         String
  leadProof           LeadProof                 @relation(fields: [leadProofId], references: [id], onDelete: Cascade)
  provider            LeadProofArtifactProvider
  artifactType        LeadProofArtifactType
  status              LeadProofArtifactStatus   @default(CAPTURED)
  externalReference   String?
  certificateUrl      String?
  integrityHash       String?
  signature           String?
  algorithm           String?
  keyId               String?
  capturedAt          DateTime?
  issuedAt            DateTime?
  verifiedAt          DateTime?
  retainedAt          DateTime?
  expiresAt           DateTime?
  artifactFingerprint String
  providerMetadata    Json?
  failureReasons      Json?
  rawArtifactPayload  Json?
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt

  @@unique([leadProofId, artifactFingerprint])
  @@index([leadProofId, provider, artifactType])
  @@index([status, updatedAt])
}

model ConsentDisclosureVersion {
  id               String    @id @default(cuid())
  versionKey       String    @unique
  sourcePlatform   String?
  formId           String?
  formName         String?
  disclosureText   String    @db.Text
  privacyPolicyUrl String?
  termsUrl         String?
  active           Boolean   @default(true)
  effectiveFrom    DateTime?
  effectiveTo      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([active, effectiveFrom])
  @@index([sourcePlatform, formId])
}

model LeadSourceSnapshot {
  id                String   @id @default(cuid())
  leadUid           String   @unique
  sourceLane        String?
  sourcePlatform    String?
  sourceType        String?
  sourceLeadId      String?
  sourceAttributes  Json?
  routingAttributes Json?
  rawPayload        Json?
  capturedAt        DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([sourceLane, capturedAt])
  @@index([sourcePlatform, sourceType, capturedAt])
}

model LeadVerificationResult {
  id                 String                 @id @default(cuid())
  leadUid            String                 @unique
  verificationStatus LeadVerificationStatus @default(UNCHECKED)
  duplicateStatus    LeadDuplicateStatus?
  phoneStatus        String?
  emailStatus        String?
  suppressionStatus  String?
  qualityScore       Int?
  reasons            Json?
  checkedAt          DateTime?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  @@index([verificationStatus, updatedAt])
  @@index([duplicateStatus, updatedAt])
}

/// Audit trail for operator-approved LF2 duplicate verification decisions.
model LeadVerificationApprovalAuditEvent {
  id                            String                             @id @default(cuid())
  sourceLeadEventId             String
  sourceLeadUidMasked           String?
  leadUid                       String
  clientAccountId               String
  destinationSubaccountIdGhl    String
  actionType                    LeadVerificationApprovalActionType
  previousVerificationStatus    LeadVerificationStatus?
  previousDuplicateStatus       LeadDuplicateStatus?
  newVerificationStatus         LeadVerificationStatus?
  newDuplicateStatus            LeadDuplicateStatus?
  phoneFingerprint              String?
  emailFingerprint              String?
  duplicateSearchClassification String?
  duplicateSearchReasonCode     String?
  phoneSearchOutcome            String?
  emailSearchOutcome            String?
  matchedContactIdGhl           String?
  approvalStatus                LeadVerificationApprovalStatus
  reasonsJson                   Json?
  metadataJson                  Json?
  requestedBy                   String?
  requestId                     String?
  createdAt                     DateTime                           @default(now())

  @@index([sourceLeadEventId, createdAt])
  @@index([leadUid, createdAt])
  @@index([clientAccountId, createdAt])
  @@index([destinationSubaccountIdGhl, createdAt])
  @@index([requestId])
}

/// Append-only audit trail for LF2 operator proof-review decisions.
model LeadProofReviewAuditEvent {
  id                         String                    @id @default(cuid())
  sourceLeadEventId          String
  leadProofId                String?
  sourceLeadUidMasked        String?
  leadUidFingerprint         String
  clientAccountId            String
  canonicalSourceLane        String
  proofPolicyKey             String
  actionType                 LeadProofReviewActionType
  previousProofStatus        LeadProofStatus?
  extractedProofStatus       LeadProofStatus?
  newProofStatus             LeadProofStatus?
  previousVerificationStatus LeadVerificationStatus?
  previousDuplicateStatus    LeadDuplicateStatus?
  reviewStatus               LeadProofReviewStatus
  evidenceSummaryJson        Json?
  reasonsJson                Json?
  metadataJson               Json?
  requestedBy                String?
  operatorNote               String?
  requestId                  String
  createdAt                  DateTime                  @default(now())

  @@unique([sourceLeadEventId, requestId])
  @@index([sourceLeadEventId, createdAt])
  @@index([clientAccountId, createdAt])
  @@index([leadProofId])
  @@index([actionType, createdAt])
  @@index([createdAt])
}

/// Audit trail for LF2 Checkpoint A configuration create/revoke decisions.
model Lf2CheckpointAAuditEvent {
  id                         String                   @id @default(cuid())
  sourceLeadEventId          String
  sourceLeadUidMasked        String?
  clientAccountId            String
  destinationSubaccountIdGhl String
  leadOrderId                String?
  deliveryTargetId           String?
  actionType                 Lf2CheckpointAActionType
  checkpointAStatus          Lf2CheckpointAStatus
  reasonsJson                Json?
  metadataJson               Json?
  requestedBy                String?
  requestId                  String?
  createdAt                  DateTime                 @default(now())

  @@index([sourceLeadEventId, createdAt])
  @@index([clientAccountId, createdAt])
  @@index([leadOrderId, createdAt])
  @@index([deliveryTargetId, createdAt])
  @@index([requestId])
}

model LifecycleEvent {
  id                String    @id @default(cuid())
  eventUuid         String    @unique
  clientAccountId   String
  subaccountIdGhl   String?
  leadUid           String
  contactIdGhl      String?
  eventNameInternal String
  eventNameMeta     String
  payloadJson       Json
  status            String    @default("received")
  receivedAt        DateTime  @default(now())
  processedAt       DateTime?
}

model MetaDispatchAttempt {
  id            String   @id @default(cuid())
  eventUuid     String
  attemptNumber Int
  requestJson   Json?
  responseJson  Json?
  httpStatus    Int?
  success       Boolean  @default(false)
  errorMessage  String?
  attemptedAt   DateTime @default(now())
}

model FailedDispatch {
  id            String   @id @default(cuid())
  eventUuid     String   @unique
  failureReason String
  retryCount    Int      @default(0)
  resolved      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

enum InboundContactSourceOrigin {
  lifecycle_webhook
  ghl_backfill
  merged
}

enum InboundContactClientStatus {
  LEAD
  EXISTING_CLIENT
  UNKNOWN
}

enum WebhookRequestSource {
  ghl_lifecycle
  synthflow_inbound_lookup
  leadcapture_io
  facebook_lead_ads
  google_sheets
}

enum SourceLeadProvider {
  leadcapture_io
  facebook
  goat_leads
  manual_import
  google_sheets
  unknown
}

enum SourceLeadSystem {
  leadcapture_io_legacy
  leadcapture_io_nextgen
  meta_lead_ads
  external_vendor
  csv_import
  google_sheet_import
}

enum SourceLeadType {
  webhook
  lead_form
  bulk_import
  api_import
  manual_entry
}

enum SourceLeadEventStatus {
  received
  normalized
  routing_matched
  routing_unmatched
  duplicate_blocked
  needs_review
  approved
  delivered
  delivery_failed
  rejected
}

enum BulkLeadImportStatus {
  uploaded
  parsing
  mapping_required
  ready_for_review
  ready_for_simulation
  simulation_running
  simulation_complete
  approved_for_delivery
  delivery_running
  paused
  partial_success
  completed
  failed
  cancelled
}

enum BulkLeadImportRowValidationStatus {
  pending
  eligible
  identity_blocked
  duplicate_review
  mapping_required
  destination_blocked
  ready_for_simulation
  excluded
  failed
}

enum BulkLeadImportRowDuplicateStatus {
  none
  within_batch_duplicate
  source_duplicate
  phone_email_review
  blocked
}

enum BulkLeadImportRowDeliveryStatus {
  pending
  simulated
  delivering
  delivered
  skipped
  failed
  cancelled
}

/// Request-level audit trail for HTTP ingest (GHL lifecycle webhook, Synthflow inbound lookup, etc.).
model WebhookRequestLog {
  id                      String               @id @default(cuid())
  requestId               String
  source                  WebhookRequestSource @default(ghl_lifecycle)
  route                   String
  receivedAt              DateTime             @default(now())
  completedAt             DateTime?
  durationMs              Int?
  processingStatus        String
  httpStatus              Int?
  clientAccountId         String?
  subaccountIdGhl         String?
  contactIdGhl            String?
  eventUuid               String?
  eventNameInternal       String?
  sourceLeadEventId       String?
  normalizedLeadUid       String?
  routingDryRunDecisionId String?
  errorCode               String?
  errorSummary            String?
  requestBodyRedacted     Json?
  responseBodyRedacted    Json?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt

  @@index([receivedAt])
  @@index([clientAccountId, receivedAt])
  @@index([processingStatus, receivedAt])
  @@index([source, receivedAt])
  @@index([eventUuid])
  @@index([sourceLeadEventId])
  @@index([normalizedLeadUid])
}

/// Durable request log for POST /voice/synthflow/inbound-lookup (additive observability; separate from GHL WebhookRequestLog).
model SynthflowRequestLog {
  id                   String    @id @default(cuid())
  requestId            String
  source               String    @default("synthflow_inbound_lookup")
  route                String    @default("/voice/synthflow/inbound-lookup")
  receivedAt           DateTime  @default(now())
  completedAt          DateTime?
  durationMs           Int?
  httpStatus           Int?
  processingStatus     String
  clientAccountId      String?
  subaccountIdGhl      String?
  fromNumber           String?
  toNumber             String?
  phoneE164            String?
  modelId              String?
  knownCaller          String?
  matchedBy            String?
  lookupStatus         String?
  overrideModelId      String?
  contactIdGhl         String?
  assignedAgentName    String?
  customerName         String?
  requestBodyRedacted  Json?
  responseBodyRedacted Json?
  errorCode            String?
  errorSummary         String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([receivedAt])
  @@index([source, receivedAt])
  @@index([lookupStatus, receivedAt])
  @@index([knownCaller, receivedAt])
  @@index([clientAccountId, receivedAt])
  @@index([subaccountIdGhl, receivedAt])
}

/// Outbound Synthflow call outcome (POST /voice/synthflow/outbound-result). Not lifecycle mutations — observability only.
model SynthflowOutboundResultLog {
  id                String    @id @default(cuid())
  requestId         String?
  callId            String
  modelId           String?
  fromNumber        String?
  toNumber          String?
  fromNumberE164    String?
  toNumberE164      String?
  contactIdGhl      String?
  clientAccountId   String?
  subaccountIdGhl   String?
  outcome           String
  booked            Boolean   @default(false)
  appointmentTime   DateTime?
  transcriptSummary String?   @db.Text
  payloadRedacted   Json?
  receivedAt        DateTime  @default(now())

  @@index([receivedAt])
  @@index([callId, receivedAt])
  @@index([outcome, receivedAt])
  @@index([clientAccountId, receivedAt])
  @@index([contactIdGhl, receivedAt])
}

/// Internal Launch Kanban board (e.g. `sa360_beta_mvp_launch`). Boards are addressed by stable string key.
model KanbanBoard {
  id        String       @id @default(cuid())
  boardKey  String       @unique
  name      String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  cards     KanbanCard[]
}

/// Individual card on a Launch Kanban board. Status + sortOrder describe column placement and intra-column order.
model KanbanCard {
  id                 String      @id @default(cuid())
  board              KanbanBoard @relation(fields: [boardKey], references: [boardKey], onDelete: Cascade)
  boardKey           String
  title              String
  description        String      @default("")
  status             String
  workstream         String
  priority           String
  dueDate            DateTime?
  owner              String?
  blocked            Boolean     @default(false)
  dependencyCount    Int         @default(0)
  tags               String[]    @default([])
  acceptanceCriteria Json?
  dependencies       Json?
  notes              String?     @db.Text
  sortOrder          Int         @default(0)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  @@index([boardKey, status, sortOrder])
  @@index([boardKey, updatedAt])
}

/// Denormalized caller/contact row for fast inbound lookup by phone, scoped per client (and subaccount).
model InboundContactIndex {
  id                String                      @id @default(cuid())
  clientAccountId   String
  /// Use "" when no subaccount so @@unique works reliably (PostgreSQL treats NULLs as distinct in UNIQUE).
  subaccountIdGhl   String                      @default("")
  phoneE164         String
  leadUid           String?
  contactIdGhl      String?
  firstName         String?
  lastName          String?
  displayName       String?
  email             String?
  state             String?
  assignedAgentId   String?
  assignedAgentName String?
  lifecycleStage    String?
  appointmentStatus String?
  policyStatus      String?
  leadType          String?
  sourceOrigin      InboundContactSourceOrigin
  clientStatus      InboundContactClientStatus?
  lastSeenAt        DateTime                    @default(now())
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt

  @@unique([clientAccountId, subaccountIdGhl, phoneE164])
  @@index([clientAccountId, phoneE164])
  @@index([contactIdGhl])
  @@index([clientAccountId])
}

// --- Phase 1 Agent Workspace: guidance, playbooks, telemetry, GHL sync audit ---

enum GuidanceResourceType {
  SCRIPT
  OBJECTION
  REFERRAL
  POLICY_REVIEW
  POLICY_DELIVERY
  FOLLOW_UP
  UNDERWRITING
  TRUST_BUILDER
}

enum ObjectionPlaybookKey {
  PRICE
  SPOUSE
  THINK_ABOUT_IT
  NOT_INTERESTED
  ALREADY_COVERED
  CALLBACK
  TRUST
  TOO_BUSY
}

enum ContactGuidanceEventActionType {
  VIEWED
  COPIED
  USED
  DISMISSED
  SENT_TO_GHL
  OUTCOME_LOGGED
}

enum AgentWorkspaceActionStatus {
  PENDING
  SYNCED
  FAILED
}

/// Versioned content for the embedded Agent Workspace (scripts, referrals, checklists, etc.).
model GuidanceResource {
  id              String               @id @default(cuid())
  /// When null, treat as global/default template for any client until overridden.
  clientAccountId String?
  nicheKey        String?
  lifecycleStage  String?
  resourceType    GuidanceResourceType
  title           String
  slug            String
  body            String               @db.Text
  tags            String[]             @default([])
  isActive        Boolean              @default(true)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  versions          GuidanceResourceVersion[]
  contactEvents     ContactGuidanceEvent[]
  scriptAssignments ClientScriptAssignment[]

  @@index([clientAccountId])
  @@index([nicheKey])
  @@index([lifecycleStage])
  @@index([clientAccountId, nicheKey])
  @@index([clientAccountId, lifecycleStage])
  @@index([clientAccountId, resourceType, isActive])
  @@index([slug])
}

/// Immutable snapshot of a `GuidanceResource` body/title for history and rollback.
model GuidanceResourceVersion {
  id         String           @id @default(cuid())
  resourceId String
  resource   GuidanceResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  /// Monotonic per resource (1, 2, 3…).
  version    Int
  title      String
  body       String           @db.Text
  createdAt  DateTime         @default(now())

  @@unique([resourceId, version])
  @@index([resourceId, createdAt])
}

/// Structured objection handling (parallel to generic `GuidanceResource` with type OBJECTION).
model ObjectionPlaybook {
  id                  String               @id @default(cuid())
  clientAccountId     String?
  nicheKey            String?
  objectionKey        ObjectionPlaybookKey
  title               String
  recommendedResponse String               @db.Text
  followUpMessage     String?              @db.Text
  nextBestAction      String?              @db.Text
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([clientAccountId])
  @@index([nicheKey])
  @@index([clientAccountId, nicheKey])
  @@index([objectionKey])
  @@index([clientAccountId, objectionKey, isActive])
}

/// Which script-style resources apply to a client (and optionally a GHL location).
model ClientScriptAssignment {
  id                 String           @id @default(cuid())
  clientAccountId    String
  /// Optional GHL location; use empty string when not scoped to match other models’ composite patterns.
  subaccountIdGhl    String           @default("")
  nicheKey           String?
  guidanceResourceId String
  guidanceResource   GuidanceResource @relation(fields: [guidanceResourceId], references: [id], onDelete: Cascade)
  sortOrder          Int              @default(0)
  isActive           Boolean          @default(true)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([clientAccountId])
  @@index([clientAccountId, subaccountIdGhl])
  @@index([guidanceResourceId])
  @@index([nicheKey])
  @@index([clientAccountId, nicheKey])
}

/// Agent interaction with guidance in the workspace (analytics + quality).
model ContactGuidanceEvent {
  id              String                         @id @default(cuid())
  contactIdGhl    String?
  leadUid         String?
  clientAccountId String
  resourceId      String?
  resource        GuidanceResource?              @relation(fields: [resourceId], references: [id], onDelete: SetNull)
  actionType      ContactGuidanceEventActionType
  metadata        Json?
  createdAt       DateTime                       @default(now())

  @@index([clientAccountId])
  @@index([contactIdGhl])
  @@index([leadUid])
  @@index([clientAccountId, contactIdGhl])
  @@index([clientAccountId, leadUid])
  @@index([resourceId])
  @@index([createdAt])
  @@index([clientAccountId, createdAt])
}

/// Outbound workspace actions (e.g. GHL sync); `actionType` is intentionally a string for forward compatibility.
model AgentWorkspaceAction {
  id              String                     @id @default(cuid())
  clientAccountId String
  subaccountIdGhl String?
  contactIdGhl    String?
  leadUid         String?
  actionType      String
  status          AgentWorkspaceActionStatus @default(PENDING)
  payloadJson     Json
  responseJson    Json?
  errorSummary    String?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt

  @@index([clientAccountId])
  @@index([contactIdGhl])
  @@index([leadUid])
  @@index([clientAccountId, contactIdGhl])
  @@index([clientAccountId, leadUid])
  @@index([status])
  @@index([actionType])
  @@index([clientAccountId, status])
  @@index([clientAccountId, subaccountIdGhl])
  @@index([createdAt])
}

// --- Phase 5A: Client onboarding (config only; no delivery execution) ---

enum ClientAccountStatus {
  active
  paused
  onboarding
  archived
}

// --- Client channel profile (Green/Blue/AI/Voice) config foundation ---
// Additive config layer. No live GHL writes; default write mode is `simulate`.

enum ClientChannelAiProvider {
  CLOSEBOT
  GHL_AI
  NONE
}

enum ClientChannelDefaultLeadChannel {
  AUTO
  BLUE
  GREEN
}

enum ClientChannelFallbackChannel {
  GREEN
  NONE
}

enum ClientChannelHealthStatus {
  HEALTHY
  WARNING
  DEGRADED
  PAUSED
}

enum ClientChannelPreferredContactWindow {
  ANYTIME_ALLOWED
  AFTERNOON_3_6
  EVENING
  CUSTOM
}

enum ClientChannelApplyScope {
  NEW_LEADS_ONLY
  ACTIVE_UNLOCKED_ONLY
  FORCE_MIGRATE_SELECTED
}

enum ClientChannelWriteMode {
  simulate
  shadow
  live
}

/// Admin-side client communication settings (Green/Blue lines, default/fallback channel,
/// AI provider, voice). Config only — no destructive/live lead mutation in this layer.
model ClientChannelProfileConfig {
  id              String @id @default(cuid())
  clientAccountId String
  /// Use "" (empty string) when not scoped to a subaccount so the composite @@unique works reliably.
  subaccountIdGhl String @default("")

  blueEnabled     Boolean @default(false)
  greenEnabled    Boolean @default(true)
  voiceEnabled    Boolean @default(false)
  closebotEnabled Boolean @default(false)
  ghlAiEnabled    Boolean @default(false)

  aiProvider         ClientChannelAiProvider         @default(NONE)
  defaultLeadChannel ClientChannelDefaultLeadChannel @default(AUTO)
  fallbackChannel    ClientChannelFallbackChannel    @default(GREEN)

  requiresSameNumberContinuity Boolean @default(true)

  blueNumber  String?
  greenNumber String?
  voiceNumber String?

  blueHealthStatus  ClientChannelHealthStatus?
  greenHealthStatus ClientChannelHealthStatus?

  sendblueMaxNoReplyAttempts Int @default(4)
  sendblueWindowDays         Int @default(4)
  textStartHour              Int @default(9)
  textEndHour                Int @default(21)

  preferredContactWindow ClientChannelPreferredContactWindow @default(ANYTIME_ALLOWED)
  applyDefaultScope      ClientChannelApplyScope             @default(NEW_LEADS_ONLY)

  writeMode ClientChannelWriteMode @default(simulate)

  lastValidatedAt DateTime?
  lastAppliedAt   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([clientAccountId, subaccountIdGhl])
  @@index([clientAccountId])
  @@index([subaccountIdGhl])
  @@index([writeMode])
}

/// Audit trail for "Apply Profile to GHL" custom-value mirror runs (simulate/shadow/live). No secrets.
model ClientProfileGhlMirrorLog {
  id              String   @id @default(cuid())
  actionType      String   @default("CLIENT_PROFILE_GHL_MIRROR")
  clientAccountId String
  subaccountIdGhl String?
  locationId      String?
  requestedBy     String?
  writeMode       String
  /// simulated | shadow_logged | live_applied | live_partial | blocked | error
  resultStatus    String
  valuesAttempted Int      @default(0)
  valuesWritten   Int      @default(0)
  valuesSkipped   Int      @default(0)
  errorSummary    String?
  /// Redacted write plan / per-value results (no tokens/secrets).
  planJson        Json?
  createdAt       DateTime @default(now())

  @@index([clientAccountId, createdAt])
  @@index([actionType, createdAt])
  @@index([locationId, createdAt])
}

/// Operator-managed client tenant profile (portal + onboarding).
model ClientAccount {
  clientAccountId     String              @id
  clientDisplayName   String
  status              ClientAccountStatus @default(onboarding)
  portalEnabled       Boolean             @default(false)
  portalDisplayName   String?
  /// Portal login email (case-insensitive match at sign-in).
  portalLoginEmail    String?             @unique
  primaryNicheKeys    Json                @default("[]")
  primaryProductTypes Json                @default("[]")
  notes               String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  ghlDestination  ClientGhlDestination?
  routingRules    CampaignRoutingRule[]
  deliveryTargets DeliveryTarget[]

  @@index([status])
}

/// Per-client GHL subaccount / opportunity delivery defaults (config only).
model ClientGhlDestination {
  id                               String        @id @default(cuid())
  clientAccountId                  String        @unique
  clientAccount                    ClientAccount @relation(fields: [clientAccountId], references: [clientAccountId], onDelete: Cascade)
  destinationSubaccountIdGhl       String
  locationName                     String?
  ghlConnectionStatus              String?
  snapshotInstalled                Boolean       @default(false)
  requiredFieldsInstalled          Boolean       @default(false)
  defaultAssignedUserIdGhl         String?
  destinationWorkflowIdGhl         String?
  destinationPipelineIdGhl         String?
  /// Primary pipeline stage (e.g. new lead).
  destinationPipelineStageIdGhl    String?
  pipelineStageContactingIdGhl     String?
  pipelineStageAppointmentSetIdGhl String?
  pipelineStageShowedIdGhl         String?
  pipelineStageSoldIdGhl           String?
  pipelineStageDeadIdGhl           String?
  opportunityCreationEnabled       Boolean       @default(true)
  /// SA360 logical key → GHL custom field UUID (from config discovery / operator save).
  sa360CustomFieldIdMapJson        Json          @default("{}")
  /// SA360 logical key → canonical SA360 value → GHL dropdown option value.
  sa360CustomFieldOptionMapJson    Json          @default("{}")
  /// When true, missing core required field mappings block live delivery readiness.
  customFieldStampRequired         Boolean       @default(false)
  /// When true, owner assignment failure blocks live canary success.
  ownerAssignmentRequired          Boolean       @default(false)
  /// When true, workflow start failure blocks live canary success.
  workflowStartRequired            Boolean       @default(false)
  /// none | direct_api | tag_trigger — default tag_trigger (no direct /workflow API unless configured).
  workflowTriggerMode              String        @default("tag_trigger")
  /// Canonical source attribute → GHL field key mapping (resolved to field ID at stamp time).
  sourceAttributeFieldMapJson      Json          @default("{}")
  /// Enrichment policy: aiContextRequired, ignoredCanonicalKeys, etc.
  sourceEnrichmentPolicyJson       Json          @default("{}")
  /// Route-specific alias overrides keyed by sourceRouteKey.
  sourceFieldAliasOverridesJson    Json          @default("{}")
  backupSheetEnabled               Boolean       @default(false)
  backupSheetId                    String?
  deliveryMode                     String        @default("shadow")
  deliveryEnabled                  Boolean       @default(false)
  clientCutoverApproved            Boolean       @default(false)
  internalApprovalStatus           String        @default("not_reviewed")
  createdAt                        DateTime      @default(now())
  updatedAt                        DateTime      @updatedAt
}

// --- Phase 4A: Campaign routing registry (dry-run only; no GHL delivery) ---

enum CampaignRoutingMatchType {
  campaign_id
  adset_id
  ad_id
  form_id_utm_campaign
  utm_campaign
  keyword_fallback
}

/// Config-driven rules mapping master VET attribution → destination client/subaccount.
model CampaignRoutingRule {
  id                            String                   @id @default(cuid())
  /// Master account that receives the inbound lead (payload `client_account_id`).
  masterClientAccountId         String
  /// Destination client tenant.
  clientAccountId               String
  destinationSubaccountIdGhl    String                   @default("")
  clientDisplayName             String?
  locationName                  String?
  nicheKey                      String?
  productType                   String?
  sourcePlatform                String?
  sourceType                    String?
  campaignId                    String?
  campaignName                  String?
  adsetId                       String?
  adId                          String?
  formId                        String?
  utmCampaign                   String?
  utmContent                    String?
  masterDatasetId               String?
  matchType                     CampaignRoutingMatchType
  /// For `keyword_fallback`: case-insensitive substring match against attribution haystack.
  keywordPattern                String?
  /// Higher value wins when multiple rules match the same tier.
  priority                      Int                      @default(100)
  active                        Boolean                  @default(true)
  effectiveStart                DateTime?
  effectiveEnd                  DateTime?
  /// Shadow / future delivery targets (Phase 4D — no external execution yet).
  destinationWorkflowIdGhl      String?
  destinationPipelineIdGhl      String?
  destinationPipelineStageIdGhl String?
  backupSheetEnabled            Boolean                  @default(false)
  backupSheetId                 String?
  defaultAssignedUserIdGhl      String?
  deliveryEnabled               Boolean                  @default(false)
  shadowDeliveryEnabled         Boolean                  @default(true)
  /// Phase 4G: guarded live delivery readiness (no external execution in this phase).
  ghlConnectionStatus           String?
  snapshotInstalled             Boolean                  @default(false)
  requiredFieldsInstalled       Boolean                  @default(false)
  /// shadow | ready_for_live | live | paused
  deliveryMode                  String                   @default("shadow")
  clientCutoverApproved         Boolean                  @default(false)
  /// not_reviewed | ready_for_review | approved | blocked
  internalApprovalStatus        String                   @default("not_reviewed")
  lastReadinessCheckAt          DateTime?
  /// not_ready | needs_config | ready_for_shadow | ready_for_live | live_enabled | blocked
  readinessStatus               String                   @default("not_ready")
  readinessWarnings             Json?
  /// Route-level override: canonical source attribute → GHL field key.
  sourceAttributeFieldMapJson   Json                     @default("{}")
  /// Route-level alias overrides for source field keys.
  sourceFieldAliasOverridesJson Json                     @default("{}")
  opportunityCreationEnabled    Boolean                  @default(true)
  createdAt                     DateTime                 @default(now())
  updatedAt                     DateTime                 @updatedAt

  clientAccountRef ClientAccount? @relation(fields: [clientAccountId], references: [clientAccountId], onDelete: Restrict)

  @@index([masterClientAccountId, active, priority])
  @@index([readinessStatus])
  @@index([clientAccountId, readinessStatus])
  @@index([masterClientAccountId, matchType, active])
  @@index([masterClientAccountId, campaignId])
  @@index([masterClientAccountId, adsetId])
  @@index([masterClientAccountId, adId])
  @@index([clientAccountId])
}

/// Persisted dry-run routing decision (no contact creation / Zapier replacement).
model RoutingDryRunDecision {
  id                             String                       @id @default(cuid())
  masterClientAccountId          String
  sourceEventUuid                String?
  sourceLeadUid                  String
  matched                        Boolean
  confidence                     String
  matchedRuleId                  String?
  destinationClientAccountId     String?
  destinationSubaccountIdGhl     String?
  matchReason                    String
  deliveryMode                   String                       @default("dry_run")
  routingEventNameInternal       String
  attributionSnapshot            Json?
  createdAt                      DateTime                     @default(now())
  /// Legacy Zapier / LeadConnector / GHL delivery observed by operator (optional).
  legacyDeliveredClientAccountId String?
  legacyDeliveredSubaccountIdGhl String?
  legacyDeliveryContactIdGhl     String?
  legacyDeliveryStatus           String?
  /// Operator validation vs SA360 dry-run prediction.
  validationStatus               String?
  validationNotes                String?
  validatedAt                    DateTime?
  validatedBy                    String?
  cleanupStatus                  String?
  cleanupReason                  String?
  cleanupMarkedAt                DateTime?
  deliveryPlan                   LeadDeliveryPlan?
