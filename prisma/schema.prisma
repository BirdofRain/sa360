}

enum LeadOrderKind {
  retainer_allocation
  pay_per_lead
}

enum LeadFulfillmentMode {
  campaign_bound
  pooled_matching
}

enum LeadEligibilityStatus {
  eligible
  review_required
  ineligible
}

enum LeadAllocationStatus {
  shadow
  reserved
  delivering
  committed
  released
  review_required
}

enum DeliveryInstructionStatus {
  planned
  queued
  executing
  completed
  failed
  canceled
  review_required
}

enum DeliveryAttemptMode {
  simulation
  live
}

enum DeliveryAttemptStatus {
  planned
  claimed
  in_progress
  succeeded
  retryable_failure
  terminal_failure
  unknown_outcome
  skipped
}

enum FulfillmentOutboxStatus {
  pending
  enqueued
  processing
  completed
  retryable_failure
  terminal_failure
}

/// Client lead order for Front Office fulfillment tracking (no billing yet).
model LeadOrder {
  id                       String                 @id @default(cuid())
  orderNumber              String                 @unique
  clientAccountId          String
  clientDisplayName        String?
  status                   LeadOrderStatus        @default(submitted)
  nicheKey                 String
  productType              String?
  statesJson               Json                   @default("[]")
  leadVolume               Int
  deliveryCadence          String?
  campaignType             String
  crmPackage               String
  aiVoiceAddon             Boolean                @default(false)
  requestedStartDate       DateTime?
  deliveryDestinationType  String?
  deliveryDestinationLabel String?
  notes                    String?
  adminNotes               String?
  trustStatusSnapshotJson  Json?
  routingRuleId            String?
  campaignId               String?
  createdByRole            LeadOrderCreatedByRole
  createdByUserId          String?
  submittedAt              DateTime?
  approvedAt               DateTime?
  activatedAt              DateTime?
  pausedAt                 DateTime?
  completedAt              DateTime?
  canceledAt               DateTime?
  /// LF2 shadow fulfillment — commercial matching fields (nullable for legacy rows).
  orderKind                LeadOrderKind?
  fulfillmentMode          LeadFulfillmentMode?
  requestedQuantity        Int?
  fulfillmentCycleStart    DateTime?
  fulfillmentCycleEnd      DateTime?
  allowedSourceLanesJson   Json                   @default("[]")
  proofPolicyKey           String?
  exclusivityRequired      Boolean                @default(false)
  fulfillmentPriority      Int                    @default(100)
  /// Shadow/reserved/fulfilled counters — shadow does not decrement requestedQuantity.
  proposedQuantity         Int                    @default(0)
  reservedQuantity         Int                    @default(0)
  fulfilledQuantity        Int                    @default(0)
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt

  leadAllocations LeadAllocation[]

  @@index([clientAccountId, createdAt])
  @@index([status, createdAt])
  @@index([nicheKey])
  @@index([orderKind, status, fulfillmentMode])
  @@index([fulfillmentPriority, activatedAt])
}

/// Channel-neutral client delivery destination (adapter resolved by adapterKey).
model DeliveryTarget {
  id                   String                @id @default(cuid())
  clientAccountId      String
  clientAccount        ClientAccount         @relation(fields: [clientAccountId], references: [clientAccountId], onDelete: Cascade)
  displayName          String
  /// Extensible adapter identifier, e.g. ghl.crm.v1, webhook.generic.v1
  adapterKey           String
  enabled              Boolean               @default(true)
  isPrimary            Boolean               @default(false)
  isRequired           Boolean               @default(false)
  /// Non-secret configuration metadata only — credentials live elsewhere.
  configMetadataJson   Json                  @default("{}")
  readinessStatus      String                @default("not_configured")
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  deliveryInstructions DeliveryInstruction[]

  @@index([clientAccountId, enabled])
  @@index([adapterKey])
}

/// Durable eligibility assessment for a source lead and policy version.
model LeadEligibilityAssessment {
  id                      String                @id @default(cuid())
  sourceLeadEventId       String
  sourceLeadEvent         SourceLeadEvent       @relation(fields: [sourceLeadEventId], references: [id], onDelete: Cascade)
  policyKey               String
  policyVersion           String
  status                  LeadEligibilityStatus
  reasonCodesJson         Json                  @default("[]")
  proofResultJson         Json?
  duplicateResultJson     Json?
  requiredFieldResultJson Json?
  geographyResultJson     Json?
  consentResultJson       Json?
  evaluatedAt             DateTime              @default(now())
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt

  @@unique([sourceLeadEventId, policyKey, policyVersion])
  @@index([status, evaluatedAt])
  @@index([policyKey, policyVersion])
}

/// Commercial allocation — who owns the lead (shadow/reserved/committed).
model LeadAllocation {
  id                        String                @id @default(cuid())
  sourceLeadEventId         String
  sourceLeadEvent           SourceLeadEvent       @relation(fields: [sourceLeadEventId], references: [id], onDelete: Cascade)
  leadOrderId               String
  leadOrder                 LeadOrder             @relation(fields: [leadOrderId], references: [id], onDelete: Restrict)
  clientAccountId           String
  status                    LeadAllocationStatus  @default(shadow)
  allocationPolicyVersion   String
  decisionReasonsJson       Json                  @default("[]")
  candidateCount            Int                   @default(0)
  idempotencyKey            String                @unique
  /// Idempotent replay key for manual reservation (one reservation claim per allocation).
  reservationIdempotencyKey String?               @unique
  reservationPolicyVersion  String?
  releaseReasonJson         Json?
  reviewReasonJson          Json?
  proposedAt                DateTime              @default(now())
  reservedAt                DateTime?
  committedAt               DateTime?
  releasedAt                DateTime?
  createdAt                 DateTime              @default(now())
  updatedAt                 DateTime              @updatedAt
  deliveryInstructions      DeliveryInstruction[]

  @@index([sourceLeadEventId])
  @@index([leadOrderId, status])
  @@index([clientAccountId, status])
  @@index([sourceLeadEventId, status])
}

/// Planned delivery instruction linking allocation to a delivery target.
model DeliveryInstruction {
  id               String                    @id @default(cuid())
  leadAllocationId String
  leadAllocation   LeadAllocation            @relation(fields: [leadAllocationId], references: [id], onDelete: Cascade)
  deliveryTargetId String
  deliveryTarget   DeliveryTarget            @relation(fields: [deliveryTargetId], references: [id], onDelete: Restrict)
  sequence         Int
  isRequired       Boolean                   @default(true)
  status           DeliveryInstructionStatus @default(planned)
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  deliveryAttempts DeliveryAttempt[]

  @@unique([leadAllocationId, deliveryTargetId])
  @@index([leadAllocationId, sequence])
}

/// Immutable audit row for each provider-neutral delivery execution attempt.
model DeliveryAttempt {
  id                    String                @id @default(cuid())
  deliveryInstructionId String
  deliveryInstruction   DeliveryInstruction   @relation(fields: [deliveryInstructionId], references: [id], onDelete: Cascade)
  adapterKey            String
  attemptNumber         Int
  idempotencyKey        String                @unique
  executionMode         DeliveryAttemptMode
  status                DeliveryAttemptStatus @default(planned)
  requestFingerprint    String?
  sanitizedRequestJson  Json?
  sanitizedResponseJson Json?
  externalReference     String?
  errorCode             String?
  errorSummary          String?
  retryable             Boolean               @default(false)
  startedAt             DateTime?
  completedAt           DateTime?
  nextRetryAt           DateTime?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@unique([deliveryInstructionId, attemptNumber])
  @@index([deliveryInstructionId, status])
  @@index([status, createdAt])
}

/// Durable fulfillment work outbox — survives enqueue failures.
model FulfillmentOutbox {
  id                String                  @id @default(cuid())
  idempotencyKey    String                  @unique
  sourceLeadEventId String
  sourceLeadEvent   SourceLeadEvent         @relation(fields: [sourceLeadEventId], references: [id], onDelete: Cascade)
  workType          String
  status            FulfillmentOutboxStatus @default(pending)
  attemptCount      Int                     @default(0)
  availableAt       DateTime                @default(now())
  lastErrorJson     Json?
  createdAt         DateTime                @default(now())
  enqueuedAt        DateTime?
  processingAt      DateTime?
  completedAt       DateTime?
  updatedAt         DateTime                @updatedAt

  @@index([status, availableAt])
  @@index([sourceLeadEventId])
  @@index([workType, status])
}
