generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ClientConfig {
  id                String   @id @default(cuid())
  clientAccountId   String   @unique
  clientName        String?
  metaPixelId       String?
  metaDatasetId     String?
  metaAccessToken   String?
  metaSyncEnabled   Boolean  @default(true)
  defaultCurrency   String   @default("USD")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model LeadAttribution {
  id             String   @id @default(cuid())
  leadUid        String   @unique
  contactIdGhl   String?
  sourcePlatform String?
  sourceType     String?
  campaignId     String?
  campaignName   String?
  adsetId        String?
  adsetName      String?
  adId           String?
  adName         String?
  fbclid         String?
  utmSource      String?
  utmMedium      String?
  utmCampaign    String?
  utmContent     String?
  utmTerm        String?
  firstTouchAt   DateTime?
  latestTouchAt  DateTime?
}

model LifecycleEvent {
  id                String   @id @default(cuid())
  eventUuid         String   @unique
  clientAccountId   String
  subaccountIdGhl   String?
  leadUid           String
  contactIdGhl      String?
  eventNameInternal String
  eventNameMeta     String
  payloadJson       Json
  status            String   @default("received")
  receivedAt        DateTime @default(now())
  processedAt       DateTime?
}

model MetaDispatchAttempt {
  id            String   @id @default(cuid())
  eventUuid     String
  attemptNumber Int
  requestJson   Json?
  responseJson  Json?
  httpStatus    Int?
  success       Boolean  @default(false)
  errorMessage  String?
  attemptedAt   DateTime @default(now())
}

model FailedDispatch {
  id             String   @id @default(cuid())
  eventUuid      String   @unique
  failureReason  String
  retryCount     Int      @default(0)
  resolved       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

enum InboundContactSourceOrigin {
  lifecycle_webhook
  ghl_backfill
  merged
}

enum InboundContactClientStatus {
  LEAD
  EXISTING_CLIENT
  UNKNOWN
}

/// Denormalized caller/contact row for fast inbound lookup by phone, scoped per client (and subaccount).
model InboundContactIndex {
  id                String                       @id @default(cuid())
  clientAccountId   String
  /// Use "" when no subaccount so @@unique works reliably (PostgreSQL treats NULLs as distinct in UNIQUE).
  subaccountIdGhl   String                       @default("")
  phoneE164         String
  leadUid           String?
  contactIdGhl      String?
  firstName         String?
  lastName          String?
  displayName       String?
  email             String?
  state             String?
  assignedAgentId   String?
  assignedAgentName String?
  lifecycleStage    String?
  appointmentStatus String?
  policyStatus      String?
  leadType          String?
  sourceOrigin      InboundContactSourceOrigin
  clientStatus      InboundContactClientStatus?
  lastSeenAt        DateTime                     @default(now())
  createdAt         DateTime                     @default(now())
  updatedAt         DateTime                     @updatedAt

  @@unique([clientAccountId, subaccountIdGhl, phoneE164])
  @@index([clientAccountId, phoneE164])
  @@index([contactIdGhl])
  @@index([clientAccountId])
}