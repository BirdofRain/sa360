generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ClientConfig {
  id                String   @id @default(cuid())
  clientAccountId   String   @unique
  clientName        String?
  metaPixelId       String?
  metaDatasetId     String?
  metaAccessToken   String?
  metaSyncEnabled   Boolean  @default(true)
  defaultCurrency   String   @default("USD")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model LeadAttribution {
  id             String   @id @default(cuid())
  leadUid        String   @unique
  contactIdGhl   String?
  sourcePlatform String?
  sourceType     String?
  campaignId     String?
  campaignName   String?
  adsetId        String?
  adsetName      String?
  adId           String?
  adName         String?
  fbclid         String?
  utmSource      String?
  utmMedium      String?
  utmCampaign    String?
  utmContent     String?
  utmTerm        String?
  firstTouchAt   DateTime?
  latestTouchAt  DateTime?
}

model LifecycleEvent {
  id                String   @id @default(cuid())
  eventUuid         String   @unique
  clientAccountId   String
  subaccountIdGhl   String?
  leadUid           String
  contactIdGhl      String?
  eventNameInternal String
  eventNameMeta     String
  payloadJson       Json
  status            String   @default("received")
  receivedAt        DateTime @default(now())
  processedAt       DateTime?
}

model MetaDispatchAttempt {
  id            String   @id @default(cuid())
  eventUuid     String
  attemptNumber Int
  requestJson   Json?
  responseJson  Json?
  httpStatus    Int?
  success       Boolean  @default(false)
  errorMessage  String?
  attemptedAt   DateTime @default(now())
}

model FailedDispatch {
  id             String   @id @default(cuid())
  eventUuid      String   @unique
  failureReason  String
  retryCount     Int      @default(0)
  resolved       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

enum InboundContactSourceOrigin {
  lifecycle_webhook
  ghl_backfill
  merged
}

enum InboundContactClientStatus {
  LEAD
  EXISTING_CLIENT
  UNKNOWN
}

enum WebhookRequestSource {
  ghl_lifecycle
  synthflow_inbound_lookup
}

/// Request-level audit trail for HTTP ingest (GHL lifecycle webhook, Synthflow inbound lookup, etc.).
model WebhookRequestLog {
  id                     String               @id @default(cuid())
  requestId              String
  source                 WebhookRequestSource @default(ghl_lifecycle)
  route                  String
  receivedAt             DateTime             @default(now())
  completedAt            DateTime?
  durationMs             Int?
  processingStatus       String
  httpStatus             Int?
  clientAccountId        String?
  subaccountIdGhl        String?
  contactIdGhl           String?
  eventUuid              String?
  eventNameInternal      String?
  errorCode              String?
  errorSummary           String?
  requestBodyRedacted    Json?
  responseBodyRedacted   Json?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  @@index([receivedAt])
  @@index([clientAccountId, receivedAt])
  @@index([processingStatus, receivedAt])
  @@index([source, receivedAt])
  @@index([eventUuid])
}

/// Durable request log for POST /voice/synthflow/inbound-lookup (additive observability; separate from GHL WebhookRequestLog).
model SynthflowRequestLog {
  id                   String    @id @default(cuid())
  requestId            String
  source               String    @default("synthflow_inbound_lookup")
  route                String    @default("/voice/synthflow/inbound-lookup")
  receivedAt           DateTime  @default(now())
  completedAt          DateTime?
  durationMs           Int?
  httpStatus           Int?
  processingStatus     String
  clientAccountId      String?
  subaccountIdGhl      String?
  fromNumber           String?
  toNumber             String?
  phoneE164            String?
  modelId              String?
  knownCaller          String?
  matchedBy            String?
  lookupStatus         String?
  overrideModelId      String?
  contactIdGhl         String?
  assignedAgentName    String?
  customerName         String?
  requestBodyRedacted  Json?
  responseBodyRedacted Json?
  errorCode            String?
  errorSummary         String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([receivedAt])
  @@index([source, receivedAt])
  @@index([lookupStatus, receivedAt])
  @@index([knownCaller, receivedAt])
  @@index([clientAccountId, receivedAt])
  @@index([subaccountIdGhl, receivedAt])
}

/// Denormalized caller/contact row for fast inbound lookup by phone, scoped per client (and subaccount).
model InboundContactIndex {
  id                String                       @id @default(cuid())
  clientAccountId   String
  /// Use "" when no subaccount so @@unique works reliably (PostgreSQL treats NULLs as distinct in UNIQUE).
  subaccountIdGhl   String                       @default("")
  phoneE164         String
  leadUid           String?
  contactIdGhl      String?
  firstName         String?
  lastName          String?
  displayName       String?
  email             String?
  state             String?
  assignedAgentId   String?
  assignedAgentName String?
  lifecycleStage    String?
  appointmentStatus String?
  policyStatus      String?
  leadType          String?
  sourceOrigin      InboundContactSourceOrigin
  clientStatus      InboundContactClientStatus?
  lastSeenAt        DateTime                     @default(now())
  createdAt         DateTime                     @default(now())
  updatedAt         DateTime                     @updatedAt

  @@unique([clientAccountId, subaccountIdGhl, phoneE164])
  @@index([clientAccountId, phoneE164])
  @@index([contactIdGhl])
  @@index([clientAccountId])
}