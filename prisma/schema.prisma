generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ClientConfig {
  id              String   @id @default(cuid())
  clientAccountId String   @unique
  clientName      String?
  metaPixelId     String?
  metaDatasetId   String?
  metaAccessToken String?
  metaSyncEnabled Boolean  @default(true)
  defaultCurrency String   @default("USD")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model LeadAttribution {
  id             String    @id @default(cuid())
  leadUid        String    @unique
  contactIdGhl   String?
  sourcePlatform String?
  sourceType     String?
  campaignId     String?
  campaignName   String?
  adsetId        String?
  adsetName      String?
  adId           String?
  adName         String?
  fbclid         String?
  utmSource      String?
  utmMedium      String?
  utmCampaign    String?
  utmContent     String?
  utmTerm        String?
  firstTouchAt   DateTime?
  latestTouchAt  DateTime?
}

model LifecycleEvent {
  id                String    @id @default(cuid())
  eventUuid         String    @unique
  clientAccountId   String
  subaccountIdGhl   String?
  leadUid           String
  contactIdGhl      String?
  eventNameInternal String
  eventNameMeta     String
  payloadJson       Json
  status            String    @default("received")
  receivedAt        DateTime  @default(now())
  processedAt       DateTime?
}

model MetaDispatchAttempt {
  id            String   @id @default(cuid())
  eventUuid     String
  attemptNumber Int
  requestJson   Json?
  responseJson  Json?
  httpStatus    Int?
  success       Boolean  @default(false)
  errorMessage  String?
  attemptedAt   DateTime @default(now())
}

model FailedDispatch {
  id            String   @id @default(cuid())
  eventUuid     String   @unique
  failureReason String
  retryCount    Int      @default(0)
  resolved      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

enum InboundContactSourceOrigin {
  lifecycle_webhook
  ghl_backfill
  merged
}

enum InboundContactClientStatus {
  LEAD
  EXISTING_CLIENT
  UNKNOWN
}

enum WebhookRequestSource {
  ghl_lifecycle
  synthflow_inbound_lookup
}

/// Request-level audit trail for HTTP ingest (GHL lifecycle webhook, Synthflow inbound lookup, etc.).
model WebhookRequestLog {
  id                   String               @id @default(cuid())
  requestId            String
  source               WebhookRequestSource @default(ghl_lifecycle)
  route                String
  receivedAt           DateTime             @default(now())
  completedAt          DateTime?
  durationMs           Int?
  processingStatus     String
  httpStatus           Int?
  clientAccountId      String?
  subaccountIdGhl      String?
  contactIdGhl         String?
  eventUuid            String?
  eventNameInternal    String?
  errorCode            String?
  errorSummary         String?
  requestBodyRedacted  Json?
  responseBodyRedacted Json?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@index([receivedAt])
  @@index([clientAccountId, receivedAt])
  @@index([processingStatus, receivedAt])
  @@index([source, receivedAt])
  @@index([eventUuid])
}

/// Durable request log for POST /voice/synthflow/inbound-lookup (additive observability; separate from GHL WebhookRequestLog).
model SynthflowRequestLog {
  id                   String    @id @default(cuid())
  requestId            String
  source               String    @default("synthflow_inbound_lookup")
  route                String    @default("/voice/synthflow/inbound-lookup")
  receivedAt           DateTime  @default(now())
  completedAt          DateTime?
  durationMs           Int?
  httpStatus           Int?
  processingStatus     String
  clientAccountId      String?
  subaccountIdGhl      String?
  fromNumber           String?
  toNumber             String?
  phoneE164            String?
  modelId              String?
  knownCaller          String?
  matchedBy            String?
  lookupStatus         String?
  overrideModelId      String?
  contactIdGhl         String?
  assignedAgentName    String?
  customerName         String?
  requestBodyRedacted  Json?
  responseBodyRedacted Json?
  errorCode            String?
  errorSummary         String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([receivedAt])
  @@index([source, receivedAt])
  @@index([lookupStatus, receivedAt])
  @@index([knownCaller, receivedAt])
  @@index([clientAccountId, receivedAt])
  @@index([subaccountIdGhl, receivedAt])
}

/// Outbound Synthflow call outcome (POST /voice/synthflow/outbound-result). Not lifecycle mutations — observability only.
model SynthflowOutboundResultLog {
  id                String    @id @default(cuid())
  requestId         String?
  callId            String
  modelId           String?
  fromNumber        String?
  toNumber          String?
  fromNumberE164    String?
  toNumberE164      String?
  contactIdGhl      String?
  clientAccountId   String?
  subaccountIdGhl   String?
  outcome           String
  booked            Boolean   @default(false)
  appointmentTime   DateTime?
  transcriptSummary String?   @db.Text
  payloadRedacted   Json?
  receivedAt        DateTime  @default(now())

  @@index([receivedAt])
  @@index([callId, receivedAt])
  @@index([outcome, receivedAt])
  @@index([clientAccountId, receivedAt])
  @@index([contactIdGhl, receivedAt])
}

/// Internal Launch Kanban board (e.g. `sa360_beta_mvp_launch`). Boards are addressed by stable string key.
model KanbanBoard {
  id        String       @id @default(cuid())
  boardKey  String       @unique
  name      String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  cards     KanbanCard[]
}

/// Individual card on a Launch Kanban board. Status + sortOrder describe column placement and intra-column order.
model KanbanCard {
  id                 String      @id @default(cuid())
  board              KanbanBoard @relation(fields: [boardKey], references: [boardKey], onDelete: Cascade)
  boardKey           String
  title              String
  description        String      @default("")
  status             String
  workstream         String
  priority           String
  dueDate            DateTime?
  owner              String?
  blocked            Boolean     @default(false)
  dependencyCount    Int         @default(0)
  tags               String[]    @default([])
  acceptanceCriteria Json?
  dependencies       Json?
  notes              String?     @db.Text
  sortOrder          Int         @default(0)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  @@index([boardKey, status, sortOrder])
  @@index([boardKey, updatedAt])
}

/// Denormalized caller/contact row for fast inbound lookup by phone, scoped per client (and subaccount).
model InboundContactIndex {
  id                String                      @id @default(cuid())
  clientAccountId   String
  /// Use "" when no subaccount so @@unique works reliably (PostgreSQL treats NULLs as distinct in UNIQUE).
  subaccountIdGhl   String                      @default("")
  phoneE164         String
  leadUid           String?
  contactIdGhl      String?
  firstName         String?
  lastName          String?
  displayName       String?
  email             String?
  state             String?
  assignedAgentId   String?
  assignedAgentName String?
  lifecycleStage    String?
  appointmentStatus String?
  policyStatus      String?
  leadType          String?
  sourceOrigin      InboundContactSourceOrigin
  clientStatus      InboundContactClientStatus?
  lastSeenAt        DateTime                    @default(now())
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt

  @@unique([clientAccountId, subaccountIdGhl, phoneE164])
  @@index([clientAccountId, phoneE164])
  @@index([contactIdGhl])
  @@index([clientAccountId])
}

// --- Phase 1 Agent Workspace: guidance, playbooks, telemetry, GHL sync audit ---

enum GuidanceResourceType {
  SCRIPT
  OBJECTION
  REFERRAL
  POLICY_REVIEW
  POLICY_DELIVERY
  FOLLOW_UP
  UNDERWRITING
  TRUST_BUILDER
}

enum ObjectionPlaybookKey {
  PRICE
  SPOUSE
  THINK_ABOUT_IT
  NOT_INTERESTED
  ALREADY_COVERED
  CALLBACK
  TRUST
  TOO_BUSY
}

enum ContactGuidanceEventActionType {
  VIEWED
  COPIED
  USED
  DISMISSED
  SENT_TO_GHL
  OUTCOME_LOGGED
}

enum AgentWorkspaceActionStatus {
  PENDING
  SYNCED
  FAILED
}

/// Versioned content for the embedded Agent Workspace (scripts, referrals, checklists, etc.).
model GuidanceResource {
  id              String               @id @default(cuid())
  /// When null, treat as global/default template for any client until overridden.
  clientAccountId String?
  nicheKey        String?
  lifecycleStage  String?
  resourceType    GuidanceResourceType
  title           String
  slug            String
  body            String               @db.Text
  tags            String[]             @default([])
  isActive        Boolean              @default(true)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  versions          GuidanceResourceVersion[]
  contactEvents     ContactGuidanceEvent[]
  scriptAssignments ClientScriptAssignment[]

  @@index([clientAccountId])
  @@index([nicheKey])
  @@index([lifecycleStage])
  @@index([clientAccountId, nicheKey])
  @@index([clientAccountId, lifecycleStage])
  @@index([clientAccountId, resourceType, isActive])
  @@index([slug])
}

/// Immutable snapshot of a `GuidanceResource` body/title for history and rollback.
model GuidanceResourceVersion {
  id         String           @id @default(cuid())
  resourceId String
  resource   GuidanceResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  /// Monotonic per resource (1, 2, 3…).
  version    Int
  title      String
  body       String           @db.Text
  createdAt  DateTime         @default(now())

  @@unique([resourceId, version])
  @@index([resourceId, createdAt])
}

/// Structured objection handling (parallel to generic `GuidanceResource` with type OBJECTION).
model ObjectionPlaybook {
  id                  String               @id @default(cuid())
  clientAccountId     String?
  nicheKey            String?
  objectionKey        ObjectionPlaybookKey
  title               String
  recommendedResponse String               @db.Text
  followUpMessage     String?              @db.Text
  nextBestAction      String?              @db.Text
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([clientAccountId])
  @@index([nicheKey])
  @@index([clientAccountId, nicheKey])
  @@index([objectionKey])
  @@index([clientAccountId, objectionKey, isActive])
}

/// Which script-style resources apply to a client (and optionally a GHL location).
model ClientScriptAssignment {
  id                 String           @id @default(cuid())
  clientAccountId    String
  /// Optional GHL location; use empty string when not scoped to match other models’ composite patterns.
  subaccountIdGhl    String           @default("")
  nicheKey           String?
  guidanceResourceId String
  guidanceResource   GuidanceResource @relation(fields: [guidanceResourceId], references: [id], onDelete: Cascade)
  sortOrder          Int              @default(0)
  isActive           Boolean          @default(true)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([clientAccountId])
  @@index([clientAccountId, subaccountIdGhl])
  @@index([guidanceResourceId])
  @@index([nicheKey])
  @@index([clientAccountId, nicheKey])
}

/// Agent interaction with guidance in the workspace (analytics + quality).
model ContactGuidanceEvent {
  id              String                         @id @default(cuid())
  contactIdGhl    String?
  leadUid         String?
  clientAccountId String
  resourceId      String?
  resource        GuidanceResource?              @relation(fields: [resourceId], references: [id], onDelete: SetNull)
  actionType      ContactGuidanceEventActionType
  metadata        Json?
  createdAt       DateTime                       @default(now())

  @@index([clientAccountId])
  @@index([contactIdGhl])
  @@index([leadUid])
  @@index([clientAccountId, contactIdGhl])
  @@index([clientAccountId, leadUid])
  @@index([resourceId])
  @@index([createdAt])
  @@index([clientAccountId, createdAt])
}

/// Outbound workspace actions (e.g. GHL sync); `actionType` is intentionally a string for forward compatibility.
model AgentWorkspaceAction {
  id              String                     @id @default(cuid())
  clientAccountId String
  subaccountIdGhl String?
  contactIdGhl    String?
  leadUid         String?
  actionType      String
  status          AgentWorkspaceActionStatus @default(PENDING)
  payloadJson     Json
  responseJson    Json?
  errorSummary    String?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt

  @@index([clientAccountId])
  @@index([contactIdGhl])
  @@index([leadUid])
  @@index([clientAccountId, contactIdGhl])
  @@index([clientAccountId, leadUid])
  @@index([status])
  @@index([actionType])
  @@index([clientAccountId, status])
  @@index([clientAccountId, subaccountIdGhl])
  @@index([createdAt])
}

// --- Phase 5A: Client onboarding (config only; no delivery execution) ---

enum ClientAccountStatus {
  active
  paused
  onboarding
  archived
}

/// Operator-managed client tenant profile (portal + onboarding).
model ClientAccount {
  clientAccountId     String              @id
  clientDisplayName   String
  status              ClientAccountStatus @default(onboarding)
  portalEnabled       Boolean             @default(false)
  portalDisplayName   String?
  /// Portal login email (case-insensitive match at sign-in).
  portalLoginEmail    String?             @unique
  primaryNicheKeys    Json                @default("[]")
  primaryProductTypes Json                @default("[]")
  notes               String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  ghlDestination ClientGhlDestination?
  routingRules   CampaignRoutingRule[]

  @@index([status])
}

/// Per-client GHL subaccount / opportunity delivery defaults (config only).
model ClientGhlDestination {
  id                            String        @id @default(cuid())
  clientAccountId               String        @unique
  clientAccount                 ClientAccount @relation(fields: [clientAccountId], references: [clientAccountId], onDelete: Cascade)
  destinationSubaccountIdGhl    String
  locationName                  String?
  ghlConnectionStatus           String?
  snapshotInstalled             Boolean       @default(false)
  requiredFieldsInstalled       Boolean       @default(false)
  defaultAssignedUserIdGhl      String?
  destinationWorkflowIdGhl      String?
  destinationPipelineIdGhl      String?
  /// Primary pipeline stage (e.g. new lead).
  destinationPipelineStageIdGhl String?
  pipelineStageContactingIdGhl  String?
  pipelineStageAppointmentSetIdGhl String?
  pipelineStageShowedIdGhl      String?
  pipelineStageSoldIdGhl        String?
  pipelineStageDeadIdGhl        String?
  opportunityCreationEnabled    Boolean       @default(true)
  /// SA360 logical key → GHL custom field UUID (from config discovery / operator save).
  sa360CustomFieldIdMapJson     Json          @default("{}")
  /// When true, missing core required field mappings block live delivery readiness.
  customFieldStampRequired      Boolean       @default(false)
  /// When true, owner assignment failure blocks live canary success.
  ownerAssignmentRequired       Boolean       @default(false)
  /// When true, workflow start failure blocks live canary success.
  workflowStartRequired         Boolean       @default(false)
  /// none | direct_api | tag_trigger — default tag_trigger (no direct /workflow API unless configured).
  workflowTriggerMode           String        @default("tag_trigger")
  backupSheetEnabled            Boolean       @default(false)
  backupSheetId                 String?
  deliveryMode                  String        @default("shadow")
  deliveryEnabled               Boolean       @default(false)
  clientCutoverApproved         Boolean       @default(false)
  internalApprovalStatus        String        @default("not_reviewed")
  createdAt                     DateTime      @default(now())
  updatedAt                     DateTime      @updatedAt
}

// --- Phase 4A: Campaign routing registry (dry-run only; no GHL delivery) ---

enum CampaignRoutingMatchType {
  campaign_id
  adset_id
  ad_id
  form_id_utm_campaign
  utm_campaign
  keyword_fallback
}

/// Config-driven rules mapping master VET attribution → destination client/subaccount.
model CampaignRoutingRule {
  id                         String                   @id @default(cuid())
  /// Master account that receives the inbound lead (payload `client_account_id`).
  masterClientAccountId      String
  /// Destination client tenant.
  clientAccountId            String
  destinationSubaccountIdGhl String                   @default("")
  clientDisplayName          String?
  locationName               String?
  nicheKey                   String?
  productType                String?
  sourcePlatform             String?
  sourceType                 String?
  campaignId                 String?
  campaignName               String?
  adsetId                    String?
  adId                       String?
  formId                     String?
  utmCampaign                String?
  utmContent                 String?
  masterDatasetId            String?
  matchType                  CampaignRoutingMatchType
  /// For `keyword_fallback`: case-insensitive substring match against attribution haystack.
  keywordPattern             String?
  /// Higher value wins when multiple rules match the same tier.
  priority                   Int                      @default(100)
  active                     Boolean                  @default(true)
  effectiveStart             DateTime?
  effectiveEnd               DateTime?
  /// Shadow / future delivery targets (Phase 4D — no external execution yet).
  destinationWorkflowIdGhl       String?
  destinationPipelineIdGhl       String?
  destinationPipelineStageIdGhl  String?
  backupSheetEnabled             Boolean                  @default(false)
  backupSheetId                  String?
  defaultAssignedUserIdGhl       String?
  deliveryEnabled                Boolean                  @default(false)
  shadowDeliveryEnabled          Boolean                  @default(true)
  /// Phase 4G: guarded live delivery readiness (no external execution in this phase).
  ghlConnectionStatus            String?
  snapshotInstalled              Boolean                  @default(false)
  requiredFieldsInstalled        Boolean                  @default(false)
  /// shadow | ready_for_live | live | paused
  deliveryMode                   String                   @default("shadow")
  clientCutoverApproved          Boolean                  @default(false)
  /// not_reviewed | ready_for_review | approved | blocked
  internalApprovalStatus         String                   @default("not_reviewed")
  lastReadinessCheckAt           DateTime?
  /// not_ready | needs_config | ready_for_shadow | ready_for_live | live_enabled | blocked
  readinessStatus                String                   @default("not_ready")
  readinessWarnings              Json?
  opportunityCreationEnabled     Boolean                  @default(true)
  createdAt                  DateTime                 @default(now())
  updatedAt                  DateTime                 @updatedAt

  clientAccountRef ClientAccount? @relation(fields: [clientAccountId], references: [clientAccountId], onDelete: Restrict)

  @@index([masterClientAccountId, active, priority])
  @@index([readinessStatus])
  @@index([clientAccountId, readinessStatus])
  @@index([masterClientAccountId, matchType, active])
  @@index([masterClientAccountId, campaignId])
  @@index([masterClientAccountId, adsetId])
  @@index([masterClientAccountId, adId])
  @@index([clientAccountId])
}

/// Persisted dry-run routing decision (no contact creation / Zapier replacement).
model RoutingDryRunDecision {
  id                         String   @id @default(cuid())
  masterClientAccountId      String
  sourceEventUuid            String?
  sourceLeadUid              String
  matched                    Boolean
  confidence                 String
  matchedRuleId              String?
  destinationClientAccountId String?
  destinationSubaccountIdGhl String?
  matchReason                String
  deliveryMode               String   @default("dry_run")
  routingEventNameInternal   String
  attributionSnapshot        Json?
  createdAt                  DateTime @default(now())
  /// Legacy Zapier / LeadConnector / GHL delivery observed by operator (optional).
  legacyDeliveredClientAccountId String?
  legacyDeliveredSubaccountIdGhl String?
  legacyDeliveryContactIdGhl     String?
  legacyDeliveryStatus           String?
  /// Operator validation vs SA360 dry-run prediction.
  validationStatus           String?
  validationNotes            String?
  validatedAt                DateTime?
  validatedBy                String?
  deliveryPlan               LeadDeliveryPlan?
  duplicateRiskAssessment    LeadDuplicateRiskAssessment?

  @@index([masterClientAccountId, createdAt])
  @@index([sourceLeadUid])
  @@index([sourceEventUuid])
  @@index([matched, createdAt])
  @@index([validationStatus, createdAt])
}

/// Shadow delivery plan for a routing decision (no GHL/Sheets/Zapier execution).
model LeadDeliveryPlan {
  id                         String   @id @default(cuid())
  routingDryRunDecisionId    String?  @unique
  routingDryRunDecision      RoutingDryRunDecision? @relation(fields: [routingDryRunDecisionId], references: [id], onDelete: SetNull)
  lifecycleEventId           String?
  masterClientAccountId      String
  sourceLeadUid              String?
  sourceContactIdGhl         String?
  sourcePhoneE164            String?
  sourceEmail                String?
  destinationClientAccountId String
  destinationSubaccountIdGhl String   @default("")
  destinationClientDisplayName String?
  nicheKey                   String?
  productType                String?
  deliveryMode               String   @default("shadow")
  status                     String   @default("planned")
  planVersion                String   @default("1.0")
  generatedAt                DateTime @default(now())
  generatedBy                String   @default("sa360_shadow_delivery")
  summary                    String?
  warnings                   Json?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
  steps                      LeadDeliveryPlanStep[]
  adapterRuns                GhlDeliveryAdapterRun[]
  liveDeliveryRuns           GhlLiveDeliveryRun[]

  @@index([masterClientAccountId, generatedAt])
  @@index([destinationClientAccountId, generatedAt])
  @@index([status, generatedAt])
}

model LeadDeliveryPlanStep {
  id                 String           @id @default(cuid())
  deliveryPlanId     String
  deliveryPlan       LeadDeliveryPlan @relation(fields: [deliveryPlanId], references: [id], onDelete: Cascade)
  stepOrder          Int
  stepType           String
  status             String           @default("planned")
  title              String
  description        String?
  targetSystem       String?
  targetId           String?
  requestPreviewJson Json?
  resultPreviewJson  Json?
  warnings           Json?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@unique([deliveryPlanId, stepOrder])
  @@index([deliveryPlanId])
}

/// GHL delivery adapter test/simulation run (Phase 4H — no external writes).
model GhlDeliveryAdapterRun {
  id                         String   @id @default(cuid())
  leadDeliveryPlanId         String
  leadDeliveryPlan           LeadDeliveryPlan @relation(fields: [leadDeliveryPlanId], references: [id], onDelete: Cascade)
  routingDryRunDecisionId    String?
  masterClientAccountId      String
  destinationClientAccountId String
  destinationSubaccountIdGhl String   @default("")
  mode                       String
  status                     String
  startedAt                  DateTime @default(now())
  completedAt                DateTime?
  durationMs                 Int?
  summary                    String?
  warnings                   Json?
  errors                     Json?
  createdBy                  String   @default("sa360_ghl_adapter_test")
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
  stepRuns                   GhlDeliveryAdapterStepRun[]

  @@index([leadDeliveryPlanId, startedAt])
  @@index([masterClientAccountId, startedAt])
  @@index([destinationClientAccountId, startedAt])
  @@index([status, startedAt])
}

model GhlDeliveryAdapterStepRun {
  id                 String              @id @default(cuid())
  adapterRunId       String
  adapterRun         GhlDeliveryAdapterRun @relation(fields: [adapterRunId], references: [id], onDelete: Cascade)
  deliveryPlanStepId String?
  stepOrder          Int
  stepType           String
  targetSystem       String              @default("ghl")
  targetId           String?
  mode               String
  status             String
  title              String
  requestPreviewJson Json?
  responsePreviewJson Json?
  validationErrors   Json?
  warnings           Json?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([adapterRunId, stepOrder])
}

/// Guarded GHL live canary delivery run (Phase 4I — manual operator execution only).
model GhlLiveDeliveryRun {
  id                         String   @id @default(cuid())
  leadDeliveryPlanId         String
  leadDeliveryPlan           LeadDeliveryPlan @relation(fields: [leadDeliveryPlanId], references: [id], onDelete: Cascade)
  routingDryRunDecisionId    String?
  campaignRoutingRuleId      String?
  masterClientAccountId      String
  destinationClientAccountId String
  destinationSubaccountIdGhl String   @default("")
  mode                       String
  status                     String
  idempotencyKey             String   @unique
  operatorConfirmationText   String?
  startedAt                  DateTime @default(now())
  completedAt                DateTime?
  durationMs                 Int?
  executedBy                 String?
  summary                    String?
  warnings                   Json?
  errors                     Json?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
  stepRuns                   GhlLiveDeliveryStepRun[]

  @@index([leadDeliveryPlanId, startedAt])
  @@index([masterClientAccountId, startedAt])
  @@index([destinationClientAccountId, startedAt])
  @@index([status, startedAt])
  @@index([idempotencyKey])
}

model GhlLiveDeliveryStepRun {
  id                 String              @id @default(cuid())
  liveRunId          String
  liveRun            GhlLiveDeliveryRun  @relation(fields: [liveRunId], references: [id], onDelete: Cascade)
  deliveryPlanStepId String?
  stepOrder          Int
  stepType           String
  targetSystem       String              @default("ghl")
  targetId           String?
  status             String
  requestRedactedJson Json?
  responseRedactedJson Json?
  externalId         String?
  errorCode          String?
  errorSummary       String?
  warnings           Json?
  startedAt          DateTime?
  completedAt        DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([liveRunId, stepOrder])
}

/// Lead identity correlation and duplicate-risk review (Phase 4H.5 — no GHL writes/merges).
model LeadDuplicateRiskAssessment {
  id                         String   @id @default(cuid())
  masterClientAccountId      String
  destinationClientAccountId String?
  destinationSubaccountIdGhl String?
  sourceEventUuid            String?
  sourceLeadUid              String?
  routingDryRunDecisionId    String?  @unique
  routingDryRunDecision      RoutingDryRunDecision? @relation(fields: [routingDryRunDecisionId], references: [id], onDelete: SetNull)
  leadDeliveryPlanId         String?
  lifecycleEventId           String?
  /// linked | needs_review | separate_person | ignored_test | orphan_appointment
  identityStatus             String   @default("needs_review")
  /// none | possible_duplicate | likely_duplicate | source_duplicate
  riskLevel                  String   @default("none")
  /// none | low | medium | high
  confidence                 String   @default("none")
  recommendedAction          String?
  reasons                    Json     @default("[]")
  candidateMatches           Json     @default("[]")
  normalizedPhone            String?
  normalizedEmail            String?
  facebookLeadId             String?
  facebookSubmissionId       String?
  firstName                  String?
  lastName                   String?
  fullName                   String?
  /// same_person | separate_person | ignored_test
  operatorOverrideStatus     String?
  operatorNotes              String?
  operatorUpdatedAt          DateTime?
  operatorUpdatedBy          String?
  evaluatedAt                DateTime @default(now())
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  @@index([masterClientAccountId, evaluatedAt])
  @@index([destinationClientAccountId, evaluatedAt])
  @@index([sourceLeadUid])
  @@index([sourceEventUuid])
  @@index([riskLevel, evaluatedAt])
  @@index([identityStatus, evaluatedAt])
  @@index([facebookLeadId])
  @@index([normalizedPhone, destinationClientAccountId])
  @@index([normalizedEmail, destinationClientAccountId])
}

/// Per-location GHL OAuth connection (Phase 5A — encrypted tokens, no browser exposure).
model GhlLocationConnection {
  id                    String   @id @default(cuid())
  clientAccountId       String?
  locationId            String   @unique
  locationName          String?
  companyId             String?
  userId                String?
  appId                 String?
  accessTokenEncrypted  String
  refreshTokenEncrypted String
  tokenExpiresAt        DateTime
  scopes                Json?
  authMode              String   @default("oauth")
  /// connected | pending_token | pending_location | expired | revoked | error
  connectionStatus      String   @default("connected")
  lastProbeAt           DateTime?
  lastError             String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([clientAccountId])
  @@index([connectionStatus, updatedAt])
  @@index([companyId])
}

/// OAuth tokens received before a real subaccount locationId is known (company/agency install).
model GhlOAuthPendingInstall {
  id                    String   @id @default(cuid())
  clientAccountId       String?
  companyId             String?
  userId                String?
  userType              String?
  appId                 String?
  versionId             String?
  accessTokenEncrypted  String
  refreshTokenEncrypted String
  tokenExpiresAt        DateTime
  scopes                Json?
  /// pending_location | reconciled | revoked
  status                String   @default("pending_location")
  lastError             String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([status, updatedAt])
  @@index([companyId, status])
  @@index([userId, status])
  @@index([appId, status])
}

/// Read-only GHL config discovery snapshot per location (Phase 5B).
model GhlLocationConfigSnapshot {
  id               String   @id @default(cuid())
  locationId       String
  clientAccountId  String?
  fetchedAt        DateTime
  locationName     String?
  locationJson     Json?
  pipelinesJson    Json?
  workflowsJson    Json?
  usersJson        Json?
  customFieldsJson Json?
  tagsJson         Json?
  errorsJson       Json?
  warningsJson     Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([locationId, fetchedAt])
  @@index([clientAccountId, fetchedAt])
}

/// Internal support tickets filed from Admin C.O.C. (Phase: support v1).
model SupportTicket {
  id                    String    @id @default(cuid())
  ticketNumber          Int       @unique @default(autoincrement())

  source                String    @default("admin_coc")
  status                String    @default("OPEN")
  priority              String    @default("NORMAL")
  category              String    @default("GENERAL")

  subject               String?
  description           String

  requesterName         String?
  requesterEmail        String?
  requesterUserId       String?

  assignedToName        String?
  assignedToUserId      String?

  clientAccountId       String?
  masterClientAccountId String?
  subaccountIdGhl       String?
  relatedEntityType     String?
  relatedEntityId       String?

  pagePath              String?
  pageUrl               String?
  queryJson             Json?
  contextJson           Json?
  userAgent             String?

  internalNotes         Json?
  resolutionSummary     String?

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  closedAt              DateTime?

  @@index([status, createdAt])
  @@index([priority, createdAt])
  @@index([category, createdAt])
  @@index([clientAccountId])
  @@index([masterClientAccountId])
  @@index([subaccountIdGhl])
  @@index([relatedEntityType, relatedEntityId])
}

/// Global runtime delivery adapter mode (admin-toggleable; env sets max capability).
model DeliveryRuntimeModeSetting {
  id                     String    @id @default("default")
  configuredRuntimeMode  String    @default("simulate")
  liveCanaryEnabledUntil DateTime?
  enabledBy              String?
  enabledAt              DateTime?
  reason                 String?
  lastChangedAt          DateTime  @updatedAt
  createdAt              DateTime  @default(now())
}

/// Audit trail for delivery runtime mode changes and live canary outcomes.
model DeliveryRuntimeModeAuditEvent {
  id                     String    @id @default(cuid())
  eventType              String
  previousMode           String?
  newMode                String?
  effectiveMode          String?
  maxAllowedMode         String?
  reason                 String?
  enabledBy              String?
  liveCanaryEnabledUntil DateTime?
  metadataJson           Json?
  createdAt              DateTime  @default(now())

  @@index([eventType, createdAt])
}
